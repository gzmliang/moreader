{
  "name": "moreader",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "MoRead - Immersive EPUB Reader with TTS, multi-format support and i18n",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:extension": "vue-tsc --noEmit && vite build --mode extension",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "epubjs": "^0.3.93",
    "jszip": "^3.10.1",
    "localforage": "^1.10.0",
    "lucide-vue-next": "^0.460.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-i18n": "^9.14.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.4",
    "vue-tsc": "^2.2.0"
  }
}
